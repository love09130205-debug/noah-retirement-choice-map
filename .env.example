# Supabase (server-only service role key; do NOT expose this in the browser)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Admin dashboard security
ADMIN_PASSWORD=change-this-to-a-strong-password
ADMIN_SESSION_SECRET=generate-a-long-random-string-at-least-32-characters

# Optional: leave empty to hide the PDF button
NEXT_PUBLIC_QUICK_CHECK_PDF_URL=
